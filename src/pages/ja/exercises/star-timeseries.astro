---
import Layout from '../../../layouts/Layout.astro';
import StarTimeSeries from '../../../components/exercises/StarTimeSeries';
import { t } from '../../../i18n/translations';

const base = import.meta.env.BASE_URL;
const lang = 'ja' as const;
const i = t(lang);
---

<Layout title={i.exercises.starTime.title} lang={lang}>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <a
      href={`${base}/${lang}/exercises/`}
      class="inline-flex items-center text-sm text-primary hover:text-primary-dark transition-colors mb-6"
    >
      &larr; {i.common.backToExercises}
    </a>
    <h1 class="text-3xl font-bold text-gray-900 mb-2">{i.exercises.starTime.title}</h1>
    <p class="text-gray-600 mb-8">{i.exercises.starTime.description}</p>
    <StarTimeSeries lang={lang} client:load />
  </section>
</Layout>
