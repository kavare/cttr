---
import Layout from '../layouts/Layout.astro';
import { joinBasePath } from '../lib/url';

const base = import.meta.env.BASE_URL;
---

<Layout lang="en" title="Page Not Found" pageType="404">
  <section class="flex-1 flex items-center justify-center px-4 py-16 sm:py-24">
    <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">
      <!-- Coffee image -->
      <div class="order-2 md:order-1 flex justify-center">
        <picture>
          <source srcset={joinBasePath(base, '/images/aaron-coffee-all_rights_reserved_aaron_hsieh.webp')} type="image/webp" />
          <img
            src={joinBasePath(base, '/images/aaron-coffee-all_rights_reserved_aaron_hsieh.png')}
            alt="Aaron with coffee"
            width="1024"
            height="1024"
            loading="eager"
            decoding="async"
            class="w-full max-w-xs mx-auto object-contain"
          />
        </picture>
      </div>

      <!-- 404 text -->
      <div class="order-1 md:order-2 text-center md:text-left">
        <h1 class="text-7xl sm:text-9xl font-bold tracking-tight text-primary/20 mb-4 font-heading">404</h1>
        <p class="text-lg text-primary/60 mb-8">Looks like this page moved overseas without telling anyone.</p>
        <nav class="flex flex-wrap justify-center md:justify-start gap-3 text-sm">
          <a href={joinBasePath(base, '/')} class="px-4 py-2 border border-primary/20 hover:border-primary transition-colors">English</a>
          <a href={joinBasePath(base, '/zh-tw/')} class="px-4 py-2 border border-primary/20 hover:border-primary transition-colors">繁體中文</a>
          <a href={joinBasePath(base, '/ja/')} class="px-4 py-2 border border-primary/20 hover:border-primary transition-colors">日本語</a>
          <a href={joinBasePath(base, '/ko/')} class="px-4 py-2 border border-primary/20 hover:border-primary transition-colors">한국어</a>
        </nav>
      </div>
    </div>
  </section>
</Layout>
