---
import '../styles/global.css';
import { joinBasePath } from '../lib/url';

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={joinBasePath(base, '/favicon-all_rights_reserved_aaron_hsieh.png')} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Page Not Found</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Source+Serif+4:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col items-center justify-center bg-surface text-primary font-sans px-4">
    <h1 class="text-6xl sm:text-8xl font-bold tracking-tight text-primary/20 mb-4 font-heading">404</h1>
    <p class="text-lg text-primary/60 mb-8">This page doesn't exist.</p>
    <nav class="flex flex-wrap justify-center gap-4 text-sm">
      <a href={joinBasePath(base, '/en/')} class="px-4 py-2 border border-primary/20 hover:border-primary transition-colors">English</a>
      <a href={joinBasePath(base, '/zh-tw/')} class="px-4 py-2 border border-primary/20 hover:border-primary transition-colors">繁體中文</a>
      <a href={joinBasePath(base, '/ja/')} class="px-4 py-2 border border-primary/20 hover:border-primary transition-colors">日本語</a>
      <a href={joinBasePath(base, '/ko/')} class="px-4 py-2 border border-primary/20 hover:border-primary transition-colors">한국어</a>
    </nav>
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        var props = { attempted_url: window.location.href, referrer: document.referrer };
        if (window.posthog) window.posthog.capture('404_page_view', props);
        if (window.mixpanel) window.mixpanel.track('404 Page View', props);
      });
    </script>
  </body>
</html>
