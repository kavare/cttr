---
import Layout from '../../layouts/Layout.astro';
import { t } from '../../i18n/translations';

const base = import.meta.env.BASE_URL;
const lang = 'en' as const;
const i = t(lang);
---

<Layout lang={lang}>
  <!-- Hero Section -->
  <section aria-label="About Aaron Hsieh" class="pt-16 sm:pt-24 pb-24 sm:pb-36">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-6xl sm:text-8xl lg:text-9xl font-black tracking-tight text-primary leading-[0.9] mb-20 sm:mb-28 uppercase">
        {i.landing.heroTitle}
      </h1>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-start">
        <!-- Left Column: Author Photo -->
        <div class="overflow-hidden">
          <img
            src={`${base}/images/author-photo.jpg`}
            alt="Aaron Hsieh - Career Coach and Engineering Manager helping people find overseas jobs"
            class="w-full object-cover object-[70%_center] aspect-[3/4] max-w-xs mx-auto md:max-w-none md:mx-0"
          />
        </div>
        <!-- Right Column: Bio Content -->
        <div class="flex flex-col justify-start">
          <h2 class="text-base sm:text-lg font-bold text-primary mb-16 sm:mb-24 leading-snug tracking-tight">
            Engineering Manager @Datadog | EX-Tech Lead @Meta | Early-Engineer @Beamery🦄 | Startups & NGOs Founder | Author | Career Coach
          </h2>
          <p class="text-[14px] text-primary/50 leading-relaxed mb-14 font-normal">
            Over the past 12+ years, I've been finding my way across three continents, living and working through Paris, London, Taipei, and California. I started as an early engineer at Beamery (now a unicorn), grew into a Tech Lead at Meta, and currently serve as an Engineering Manager at Datadog. Along the way, I've crossed Siberia by rail, summited Kilimanjaro, trekked the Annapurna circuit, and road tripped Route 66 with a one year old in tow. This book distills everything I've learned about navigating visa processes, cultural shifts, and the challenges of building a career far from home into a practical guide for anyone dreaming of working abroad.
          </p>
          <div>
            <a
              href={`${base}/${lang}/exercises/`}
              class="inline-flex items-center px-7 py-3 text-xs font-medium border border-primary text-primary hover:bg-primary hover:text-surface transition-colors tracking-[0.15em] uppercase"
            >
              Start Your Journey
              <svg class="ml-2 w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Book Section -->
  <article aria-label="Book: A Beginner Guide to Find Your First Overseas Jobs" class="py-20 sm:py-28 border-t border-primary/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-[5fr_7fr] gap-12 md:gap-16 items-start">
        <!-- Left: Title + Subtitle + Quote + Text -->
        <div class="flex flex-col md:order-1">
          <h2 class="text-3xl sm:text-5xl font-bold text-primary mb-4 tracking-tight">
            My Work
          </h2>
          <p class="text-lg sm:text-xl text-primary/45 mb-8">
            A Beginner Guide to Find Your First Overseas Jobs
          </p>
          <blockquote class="border-l-2 border-primary/30 pl-4 mb-10">
            <p class="text-[15px] text-primary/70 italic">"Trust yourself. You always have more options than you think."</p>
          </blockquote>
          <p class="text-[14px] text-primary/50 leading-relaxed mb-5">
            {i.landing.bookDescription}
          </p>
          <p class="text-[14px] text-primary/50 leading-relaxed mb-4">
            After struggling with job rejections post military service and a failed startup, the author had no study abroad experience, no foreign residency, and only two years of local work experience when he launched his overseas career. He has since received offers from numerous companies across Europe and the US, and helped many others do the same. Drawing on over five years of community sharing and career coaching, this book introduces the original <span class="font-bold text-primary">LIST Principles</span>. Even from Taiwan, you can use this framework to iterate, experiment, and close the distance between you and the world.
          </p>
          <dl class="text-[14px] text-primary/50 leading-relaxed mb-8 space-y-1">
            <div>
              <dt class="inline font-bold text-primary">Localize</dt>
              <dd class="inline"> — Blend in like a local. Adapt your resume, language, and cultural awareness to match your target market.</dd>
            </div>
            <div>
              <dt class="inline font-bold text-primary">Internationalize</dt>
              <dd class="inline"> — Make yourself visible to the world. Build an online presence that recruiters across borders can find.</dd>
            </div>
            <div>
              <dt class="inline font-bold text-primary">Strengthen</dt>
              <dd class="inline"> — Build internationally transferable expertise. Develop skills valued by global employers.</dd>
            </div>
            <div>
              <dt class="inline font-bold text-primary">Test</dt>
              <dd class="inline"> — Use free market signals to measure your readiness. Apply strategically and learn from every response.</dd>
            </div>
          </dl>
          <div>
            <a
              href="https://www.eslite.com/product/1001116042682161135005?srsltid=AfmBOooxk6OLJwkcMkBR3aLfXLnIlWk_QR2fAVj1hn8MzMJqWcnJWPoB"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center px-7 py-3 text-xs font-medium border border-primary text-primary hover:bg-primary hover:text-surface transition-colors tracking-[0.15em] uppercase"
            >
              Get the Book
            </a>
          </div>
        </div>
        <!-- Right: Book Cover -->
        <div class="md:order-2">
          <img
            src={`${base}/images/book-cover.png`}
            alt="Book Cover - A Beginner Guide to Find Your First Overseas Jobs by Aaron Hsieh"
            class="w-full drop-shadow-xl max-w-[280px] mx-auto md:max-w-none md:mx-0"
          />
        </div>
      </div>
    </div>
  </article>

  <!-- CTA Section -->
  <section aria-label="LIST Principles interactive exercises" class="py-20 sm:py-28 border-t border-primary/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-5xl font-bold text-primary mb-4 tracking-tight">
        LIST Principles in Practice
      </h2>
      <p class="text-lg sm:text-xl text-primary/45 mb-20 sm:mb-28">
        Start Anywhere. Build your overseas career right away.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-start">
        <!-- Left: Image + Description + CTA -->
        <div class="flex flex-col md:order-1">
          <img src={`${base}/images/list-cycle.png`} alt="LIST Cycle diagram showing Localize, Internationalize, Strengthen, and Test phases" class="w-full mb-8 max-w-sm mx-auto md:max-w-none md:mx-0" />
          <p class="text-[14px] text-primary/50 leading-relaxed mb-8">
            Put the LIST Principles into action with five interactive exercises. Track your visa research, build your STAR stories, map behavioral interview questions, monitor your weekly job search metrics, and manage your application pipeline from submission to offer.
          </p>
          <div>
            <a
              href={`${base}/${lang}/resources`}
              class="inline-flex items-center px-7 py-3 text-xs font-medium border border-primary text-primary hover:bg-primary hover:text-surface transition-colors tracking-[0.15em] uppercase"
            >
              More Career Resources
              <svg class="ml-2 w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </a>
          </div>
        </div>
        <!-- Right: Exercise List -->
        <div class="md:order-2 bg-primary/[0.03] border border-primary/10 p-8 sm:p-12">
          <ol class="space-y-5 list-none">
            <li class="flex items-center gap-4">
              <span class="text-2xl font-bold text-primary/20">01</span>
              <span class="text-sm font-medium text-primary/70">Visa Memo for Dream Countries</span>
            </li>
            <li class="flex items-center gap-4">
              <span class="text-2xl font-bold text-primary/20">02</span>
              <span class="text-sm font-medium text-primary/70">STAR Storybook (Time-series)</span>
            </li>
            <li class="flex items-center gap-4">
              <span class="text-2xl font-bold text-primary/20">03</span>
              <span class="text-sm font-medium text-primary/70">STAR Storybook (Questions-based)</span>
            </li>
            <li class="flex items-center gap-4">
              <span class="text-2xl font-bold text-primary/20">04</span>
              <span class="text-sm font-medium text-primary/70">LIST Principles Dashboard</span>
            </li>
            <li class="flex items-center gap-4">
              <span class="text-2xl font-bold text-primary/20">05</span>
              <span class="text-sm font-medium text-primary/70">LIST Principles Funnel</span>
            </li>
          </ol>
        </div>
      </div>
    </div>
  </section>
</Layout>
