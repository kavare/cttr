---
import Layout from '../../../layouts/Layout.astro';
import { t } from '../../../i18n/translations';

const base = import.meta.env.BASE_URL;
const lang = 'en' as const;
const i = t(lang);

const exercises = [
  {
    href: `${base}/${lang}/exercises/visa-memo`,
    title: i.exercises.visaMemo.title,
    description: i.exercises.visaMemo.description,
  },
  {
    href: `${base}/${lang}/exercises/star-timeseries`,
    title: i.exercises.starTime.title,
    description: i.exercises.starTime.description,
  },
  {
    href: `${base}/${lang}/exercises/star-questions`,
    title: i.exercises.starQuestions.title,
    description: i.exercises.starQuestions.description,
  },
  {
    href: `${base}/${lang}/exercises/list-dashboard`,
    title: i.exercises.listDashboard.title,
    description: i.exercises.listDashboard.description,
  },
  {
    href: `${base}/${lang}/exercises/list-funnel`,
    title: i.exercises.listFunnel.title,
    description: i.exercises.listFunnel.description,
  },
];
---

<Layout title={i.exercises.title} lang={lang} description={i.exercises.description}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-3xl sm:text-4xl font-bold text-primary text-center mb-3">{i.exercises.title}</h1>
    <div class="w-16 h-1 bg-accent mx-auto rounded-full mb-4"></div>
    <p class="text-lg text-primary/60 text-center mb-10">{i.exercises.description}</p>

    <div class="grid gap-4">
      {exercises.map((exercise) => (
        <a
          href={exercise.href}
          class="block p-6 border border-primary/10 hover:border-primary/30 hover:shadow-md transition-all"
        >
          <h2 class="text-lg font-semibold text-primary mb-1">{exercise.title}</h2>
          <p class="text-sm text-primary/50">{exercise.description}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>
