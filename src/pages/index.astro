---
// Redirect to the appropriate locale based on browser language
const base = import.meta.env.BASE_URL;
const basePath = base === '/' ? '' : base;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Redirecting...</title>
    <script is:inline define:vars={{ base }}>
      const lang = navigator.language || navigator.languages?.[0] || 'en';
      if (lang.startsWith('zh')) {
        window.location.replace((base === '/' ? '' : base) + '/zh-tw/');
      } else if (lang.startsWith('ja')) {
        window.location.replace((base === '/' ? '' : base) + '/ja/');
      } else if (lang.startsWith('ko')) {
        window.location.replace((base === '/' ? '' : base) + '/ko/');
      } else {
        window.location.replace((base === '/' ? '' : base) + '/en/');
      }
    </script>
    <meta http-equiv="refresh" content={`0;url=${basePath}/en/`} />
  </head>
  <body>
    <p>Redirecting...</p>
  </body>
</html>
