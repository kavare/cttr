---
import Layout from '../layouts/Layout.astro';
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang);
const base = import.meta.env.BASE_URL;

const articles = [
  {
    href: 'https://medium.com/dimly-lit/how-to-find-jobs-in-uk-chap-concept-8961894f2749',
    title: i.essays.article1Title,
    description: i.essays.article1Description,
  },
  {
    href: 'https://medium.com/dimly-lit/how-to-find-jobs-in-uk-chap-channel-b878a3a46f2a',
    title: i.essays.article2Title,
    description: i.essays.article2Description,
  },
  {
    href: 'https://medium.com/dimly-lit/self-intro-interview-prep-tips-475319357048',
    title: i.essays.article3Title,
    description: i.essays.article3Description,
  },
];
---

<Layout lang={lang} title={i.essays.title}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-3xl sm:text-4xl font-bold text-primary text-center mb-3">{i.essays.title}</h1>
    <div class="w-16 h-1 bg-accent mx-auto rounded-full mb-6"></div>
    <p class="text-lg text-primary/60 text-center mb-14 max-w-2xl mx-auto" set:html={i.essays.subtitle}></p>

    <div class="grid gap-6 max-w-2xl mx-auto">
      {articles.map((article) => (
        <a
          href={article.href}
          target="_blank"
          rel="noopener noreferrer"
          class="block p-8 bg-surface-dark/40 border border-primary/10 rounded-lg hover:border-primary/30 hover:shadow-md transition-all group"
        >
          <div class="flex items-start gap-5">
            <div class="flex-shrink-0 w-12 h-12 bg-primary/5 rounded-full flex items-center justify-center group-hover:bg-primary/10 transition-colors">
              <svg class="w-6 h-6 text-primary/60" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
              </svg>
            </div>
            <div>
              <h2 class="text-lg font-semibold text-primary mb-2">{article.title}</h2>
              <p class="text-sm text-primary/50">{article.description}</p>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="text-center mt-12">
      <a href="https://medium.com/dimly-lit" target="_blank" rel="noopener noreferrer" class="cta-link">
        {i.essays.viewAll}
        <svg class="ml-2 w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
      </a>
    </div>
  </section>
</Layout>
