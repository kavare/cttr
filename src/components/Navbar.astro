---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';
import { joinBasePath } from '../lib/url';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang);
const base = import.meta.env.BASE_URL;
const basePrefix = base === '/' ? '' : base;

// Build switch paths for all other languages
const currentPath = Astro.url.pathname;
const pathWithoutLang = currentPath.replace(new RegExp(`^${basePrefix || ''}/(en|zh-tw|ja|ko)`), '');

const langOptions: { code: Lang; label: string }[] = [
  { code: 'en', label: 'EN' },
  { code: 'zh-tw', label: 'TW' },
  { code: 'ja', label: 'JP' },
  { code: 'ko', label: 'KO' },
];
const otherLangs = langOptions.filter((l) => l.code !== lang);
const currentLang = langOptions.find((l) => l.code === lang)!;

// Determine active nav item
const stripped = pathWithoutLang.replace(/^\//, '').replace(/\/$/, '');
const isHome = stripped === '' || stripped === '/';
const isExercises = stripped.startsWith('exercises');
const isResources = stripped.startsWith('resources');
const isCoffeeChat = stripped.startsWith('coffee-chat');
const isEssays = stripped.startsWith('essays');

const navClass = (active: boolean) =>
  active
    ? 'text-sm font-medium text-primary border-b-2 border-primary pb-0.5 transition-colors'
    : 'text-sm font-medium text-primary/50 hover:text-primary transition-colors';

const mobileNavClass = (active: boolean) =>
  active
    ? 'block px-3 py-2 text-sm font-medium text-primary border-l-2 border-primary'
    : 'block px-3 py-2 text-sm font-medium text-primary/50 hover:text-primary';
---

<nav class="sticky top-0 z-50 bg-[#f0ede6] border-b border-primary/10">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">
      <a href={joinBasePath(base, `/${lang}/`)} class="flex items-center gap-2 font-bold text-primary tracking-tight hover:opacity-70 transition-opacity min-w-0 text-sm lg:text-base">
        <img src={joinBasePath(base, '/images/logo-all_rights_reserved_aaron_hsieh.png')} alt="" class="h-7 w-auto shrink-0" />
        <span class="truncate">{i.nav.brand}</span>
      </a>

      <div class="hidden lg:flex items-center gap-8">
        <a href={joinBasePath(base, `/${lang}/`)} class={navClass(isHome)}>
          {i.nav.home}
        </a>
        <a href={joinBasePath(base, `/${lang}/exercises/`)} class={navClass(isExercises)}>
          {i.nav.exercises}
        </a>
        <a href={joinBasePath(base, `/${lang}/resources`)} class={navClass(isResources)}>
          {i.nav.resources}
        </a>
        <a href={joinBasePath(base, `/${lang}/essays`)} class={navClass(isEssays)}>
          {i.nav.essays}
        </a>
        <a href={joinBasePath(base, `/${lang}/coffee-chat`)} class={navClass(isCoffeeChat)}>
          {i.nav.coffeechat}
        </a>
        <div class="inline-flex items-center px-3 py-1 text-xs font-medium border border-primary/20 text-primary/70 gap-1">
          {otherLangs.map((l, idx) => (
            <>
              {idx > 0 && <span class="text-primary/30">/</span>}
              <a href={joinBasePath(base, `/${l.code}${pathWithoutLang}`)} class="hover:text-primary transition-colors">{l.label}</a>
            </>
          ))}
        </div>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-primary/70 hover:text-primary"
        aria-label="Toggle menu"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden lg:hidden pb-4">
      <div class="flex flex-col gap-1">
        <a href={joinBasePath(base, `/${lang}/`)} class={mobileNavClass(isHome)}>
          {i.nav.home}
        </a>
        <a href={joinBasePath(base, `/${lang}/exercises/`)} class={mobileNavClass(isExercises)}>
          {i.nav.exercises}
        </a>
        <a href={joinBasePath(base, `/${lang}/resources`)} class={mobileNavClass(isResources)}>
          {i.nav.resources}
        </a>
        <a href={joinBasePath(base, `/${lang}/essays`)} class={mobileNavClass(isEssays)}>
          {i.nav.essays}
        </a>
        <a href={joinBasePath(base, `/${lang}/coffee-chat`)} class={mobileNavClass(isCoffeeChat)}>
          {i.nav.coffeechat}
        </a>
      </div>
      <div class="mt-3 pt-3 border-t border-primary/10 flex items-center gap-1 px-3">
        {langOptions.map((l, idx) => (
          <>
            {idx > 0 && <span class="text-primary/15 text-xs">/</span>}
            {l.code === lang ? (
              <span class="px-2 py-1 text-xs font-semibold text-primary">{l.label}</span>
            ) : (
              <a href={joinBasePath(base, `/${l.code}${pathWithoutLang}`)} class="px-2 py-1 text-xs font-medium text-primary/40 hover:text-primary transition-colors">{l.label}</a>
            )}
          </>
        ))}
      </div>
    </div>
  </div>
</nav>

<script is:inline>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
