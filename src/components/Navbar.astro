---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang);
const base = import.meta.env.BASE_URL;

// Build switch paths for all other languages
const currentPath = Astro.url.pathname;
const pathWithoutLang = currentPath.replace(new RegExp(`^${base}/(en|zh-tw|ja)`), '');

const langOptions: { code: Lang; label: string }[] = [
  { code: 'en', label: 'EN' },
  { code: 'zh-tw', label: 'ZH' },
  { code: 'ja', label: 'JA' },
];
const otherLangs = langOptions.filter((l) => l.code !== lang);
---

<nav class="sticky top-0 z-50 bg-surface border-b border-primary/10">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">
      <a href={`${base}/${lang}/`} class="text-base font-bold text-primary tracking-tight hover:opacity-70 transition-opacity">
        On the Road
      </a>

      <div class="hidden sm:flex items-center gap-8">
        <a href={`${base}/${lang}/`} class="text-sm font-medium text-primary/70 hover:text-primary transition-colors">
          {i.nav.home}
        </a>
        <a href={`${base}/${lang}/exercises/`} class="text-sm font-medium text-primary/70 hover:text-primary transition-colors">
          {i.nav.exercises}
        </a>
        <a href={`${base}/${lang}/resources`} class="text-sm font-medium text-primary/70 hover:text-primary transition-colors">
          {i.nav.resources}
        </a>
        <div class="inline-flex items-center px-3 py-1 text-xs font-medium border border-primary/20 text-primary/70 gap-1">
          {otherLangs.map((l, idx) => (
            <>
              {idx > 0 && <span class="text-primary/30">/</span>}
              <a href={`${base}/${l.code}${pathWithoutLang}`} class="hover:text-primary transition-colors">{l.label}</a>
            </>
          ))}
        </div>
      </div>

      <!-- Mobile menu button -->
      <div class="sm:hidden flex items-center gap-3">
        <div class="inline-flex items-center px-2.5 py-1 text-xs font-medium border border-primary/20 text-primary/70 gap-1">
          {otherLangs.map((l, idx) => (
            <>
              {idx > 0 && <span class="text-primary/30">/</span>}
              <a href={`${base}/${l.code}${pathWithoutLang}`} class="hover:text-primary transition-colors">{l.label}</a>
            </>
          ))}
        </div>
        <button
          id="mobile-menu-btn"
          class="p-2 text-primary/70 hover:text-primary"
          aria-label="Toggle menu"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden sm:hidden pb-4">
      <div class="flex flex-col gap-1">
        <a href={`${base}/${lang}/`} class="block px-3 py-2 text-sm font-medium text-primary/70 hover:text-primary">
          {i.nav.home}
        </a>
        <a href={`${base}/${lang}/exercises/`} class="block px-3 py-2 text-sm font-medium text-primary/70 hover:text-primary">
          {i.nav.exercises}
        </a>
        <a href={`${base}/${lang}/resources`} class="block px-3 py-2 text-sm font-medium text-primary/70 hover:text-primary">
          {i.nav.resources}
        </a>
      </div>
    </div>
  </div>
</nav>

<script is:inline>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
