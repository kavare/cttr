---
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang);
const otherLang = lang === 'en' ? 'zh-tw' : 'en';
const otherLangLabel = lang === 'en' ? '繁中' : 'EN';

// Build the equivalent path in the other language
const currentPath = Astro.url.pathname;
const pathWithoutLang = currentPath.replace(/^\/(en|zh-tw)/, '');
const switchPath = `/${otherLang}${pathWithoutLang}`;
---

<nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href={`/${lang}/`} class="text-lg font-bold text-primary hover:text-primary-light transition-colors">
        CTTR
      </a>

      <div class="hidden sm:flex items-center gap-6">
        <a href={`/${lang}/`} class="text-sm font-medium text-gray-700 hover:text-primary transition-colors">
          {i.nav.home}
        </a>
        <a href={`/${lang}/exercises/visa-memo`} class="text-sm font-medium text-gray-700 hover:text-primary transition-colors">
          {i.nav.exercises}
        </a>
        <a href={`/${lang}/resources`} class="text-sm font-medium text-gray-700 hover:text-primary transition-colors">
          {i.nav.resources}
        </a>
        <a
          href={switchPath}
          class="inline-flex items-center px-3 py-1.5 text-sm font-medium rounded-full border border-gray-300 hover:bg-gray-100 transition-colors"
        >
          {otherLangLabel}
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="sm:hidden flex items-center gap-3">
        <a
          href={switchPath}
          class="inline-flex items-center px-2.5 py-1 text-xs font-medium rounded-full border border-gray-300 hover:bg-gray-100 transition-colors"
        >
          {otherLangLabel}
        </a>
        <button
          id="mobile-menu-btn"
          class="p-2 rounded-md text-gray-700 hover:bg-gray-100"
          aria-label="Toggle menu"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden sm:hidden pb-4">
      <div class="flex flex-col gap-2">
        <a href={`/${lang}/`} class="block px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100 rounded-md">
          {i.nav.home}
        </a>
        <a href={`/${lang}/exercises/visa-memo`} class="block px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100 rounded-md">
          {i.nav.exercises}
        </a>
        <a href={`/${lang}/resources`} class="block px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-100 rounded-md">
          {i.nav.resources}
        </a>
      </div>
    </div>
  </div>
</nav>

<script is:inline>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu')?.classList.toggle('hidden');
  });
</script>
