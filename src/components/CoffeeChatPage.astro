---
import Layout from '../layouts/Layout.astro';
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const i = t(lang);
const base = import.meta.env.BASE_URL;
---

<Layout lang={lang} title={i.coffeechat.title} description={i.coffeechat.subtitle}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-3xl sm:text-4xl font-bold text-primary text-center mb-3">{i.coffeechat.title}</h1>
    <div class="w-16 h-1 bg-accent mx-auto rounded-full mb-6"></div>
    <p class="text-lg text-primary/60 text-center mb-14 max-w-2xl mx-auto" set:html={i.coffeechat.subtitle}></p>

    <div class="grid gap-6 max-w-2xl mx-auto">
      <!-- Calendly CTA -->
      <a
        href="https://calendly.com/aaron-hsieh-nexf/30min"
        target="_blank"
        rel="noopener noreferrer"
        class="block p-8 bg-surface-dark/40 border border-primary/10 rounded-lg hover:border-primary/30 hover:shadow-md transition-all group"
      >
        <div class="flex items-start gap-5">
          <div class="flex-shrink-0 w-12 h-12 bg-primary/5 rounded-full flex items-center justify-center group-hover:bg-primary/10 transition-colors">
            <svg class="w-6 h-6 text-primary/60" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
            </svg>
          </div>
          <div>
            <h2 class="text-lg font-semibold text-primary mb-2">{i.coffeechat.calendlyTitle}</h2>
            <p class="text-sm text-primary/50">{i.coffeechat.calendlyDescription}</p>
          </div>
        </div>
      </a>

      <!-- LinkedIn CTA -->
      <a
        href="https://www.linkedin.com/in/aarontthsieh/"
        target="_blank"
        rel="noopener noreferrer"
        class="block p-8 bg-surface-dark/40 border border-primary/10 rounded-lg hover:border-primary/30 hover:shadow-md transition-all group"
      >
        <div class="flex items-start gap-5">
          <div class="flex-shrink-0 w-12 h-12 bg-primary/5 rounded-full flex items-center justify-center group-hover:bg-primary/10 transition-colors">
            <svg class="w-6 h-6 text-primary/60" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </div>
          <div>
            <h2 class="text-lg font-semibold text-primary mb-2">{i.coffeechat.linkedinTitle}</h2>
            <p class="text-sm text-primary/50">{i.coffeechat.linkedinDescription}</p>
          </div>
        </div>
      </a>
    </div>
  </section>
</Layout>
