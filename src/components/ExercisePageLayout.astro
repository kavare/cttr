---
import Layout from '../layouts/Layout.astro';
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

type ExerciseKey = 'visaMemo' | 'starTime' | 'starQuestions' | 'listDashboard' | 'listFunnel';

interface Props {
  lang: Lang;
  exerciseKey: ExerciseKey;
  containerClass?: string;
  headingClass?: string;
}

const { lang, exerciseKey, containerClass = 'max-w-6xl mx-auto px-4 py-10', headingClass = 'text-2xl font-bold text-gray-900 mb-2' } = Astro.props;
const base = import.meta.env.BASE_URL;
const i = t(lang);
const exercise = i.exercises[exerciseKey];
---

<Layout title={exercise.title} lang={lang}>
  <section class={containerClass}>
    <a
      href={`${base}/${lang}/exercises/`}
      class="inline-flex items-center text-xs font-medium tracking-wide uppercase text-primary/40 hover:text-primary transition-colors mb-6 gap-1.5"
    >
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 12H5m0 0l5-5m-5 5l5 5" /></svg>
      {i.common.backToExercises}
    </a>
    <h1 class={headingClass}>
      {exercise.title}
    </h1>
    <p class="text-gray-600 mb-8">
      {exercise.description}
    </p>
    <slot />
  </section>
</Layout>
