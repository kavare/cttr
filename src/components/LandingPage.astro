---
import Layout from '../layouts/Layout.astro';
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';
import { joinBasePath } from '../lib/url';

interface Props {
  lang: Lang;
  isRoot?: boolean;
  canonicalOverride?: string;
}

const { lang, isRoot = false, canonicalOverride } = Astro.props;
const base = import.meta.env.BASE_URL;
const i = t(lang);
const sectionTitle = `text-2xl sm:text-3xl ${lang === 'en' ? 'font-black' : 'font-bold'} text-primary uppercase tracking-tight leading-tight font-heading`;
---

<Layout lang={lang} pageType="home" canonicalOverride={canonicalOverride}>
  <!-- Hero: Name Title -->
  <section aria-label={i.landing.heroAriaLabel} class="pt-8 sm:pt-14">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-6xl sm:text-8xl lg:text-9xl font-bold tracking-[-0.07em] text-primary leading-[0.85] uppercase -mb-9 sm:-mb-9">
        {i.landing.heroTitle}
      </h1>
    </div>
  </section>

  <!-- Book Section -->
  <article aria-label={i.landing.bookSectionAriaLabel} class="py-20 sm:py-28">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-x-20 md:gap-y-0 items-start">
        <!-- Left: Book Cover (on desktop) -->
        <div class="md:row-span-2 md:order-1 order-2">
          <picture>
            <source srcset={joinBasePath(base, '/images/book-cover-all_rights_reserved_aaron_hsieh.webp')} type="image/webp" />
            <img
              src={joinBasePath(base, '/images/book-cover-all_rights_reserved_aaron_hsieh.png')}
              alt={i.landing.bookCoverAlt}
              width="518"
              height="720"
              loading="eager"
              decoding="async"
              class="w-full drop-shadow-xl max-w-[280px] mx-auto md:max-w-none md:mx-0"
            />
          </picture>
        </div>
        <!-- Right: Quote as title -->
        <div class="flex flex-col md:order-2 order-1">
          <h2 class="text-2xl sm:text-3xl font-black text-primary leading-tight tracking-tight uppercase font-heading mb-8 sm:mb-12" set:html={i.landing.quote}>
          </h2>
        </div>
        <!-- Right continued: Body + CTA -->
        <div class="flex flex-col md:order-3 order-3">
          <p class="text-[15px] text-primary/50 leading-relaxed mb-5">
            {i.landing.bookDescription}
          </p>
          <p class="text-[15px] text-primary/50 leading-relaxed mb-4" set:html={i.landing.listParagraph}>
          </p>
          <dl class="text-[15px] text-primary/50 leading-relaxed mb-8 space-y-1">
            <div>
              <dt class="inline font-bold text-primary">Localize</dt>
              <dd class="inline">{i.landing.listL}</dd>
            </div>
            <div>
              <dt class="inline font-bold text-primary">Internationalize</dt>
              <dd class="inline">{i.landing.listI}</dd>
            </div>
            <div>
              <dt class="inline font-bold text-primary">Strengthen</dt>
              <dd class="inline">{i.landing.listS}</dd>
            </div>
            <div>
              <dt class="inline font-bold text-primary">Test</dt>
              <dd class="inline">{i.landing.listT}</dd>
            </div>
          </dl>
          <div>
            <a
              href="https://www.eslite.com/product/1001116042682161135005?srsltid=AfmBOooxk6OLJwkcMkBR3aLfXLnIlWk_QR2fAVj1hn8MzMJqWcnJWPoB"
              target="_blank"
              rel="noopener noreferrer"
              class="cta-link"
              data-track="book_purchase_click"
              data-track-dest="eslite"
            >
              {i.landing.bookCta}
            </a>
          </div>
        </div>
      </div>
    </div>
  </article>

  <!-- About the Author -->
  <section aria-label={i.landing.heroAriaLabel} class="py-20 sm:py-28 border-t border-primary/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-start">
        <!-- Left: Bio Content (on desktop) -->
        <div class="flex flex-col justify-start md:order-1 order-2">
          <h2 class={`${sectionTitle} mb-16 sm:mb-24`} set:html={i.landing.jobTitle}>
          </h2>
          <p class="text-[15px] text-primary/50 leading-relaxed mb-14 font-normal" set:html={i.landing.bioText}>
          </p>
          <div>
            <a href={joinBasePath(base, `/${lang}/exercises/`)} class="cta-link" data-track="cta_click" data-track-dest="exercises">
              {i.landing.heroCtaText}
              <svg class="ml-2 w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </a>
          </div>
        </div>
        <!-- Right: Author Photo (on desktop) -->
        <div class="overflow-hidden md:order-2 order-1">
          <picture>
            <source srcset={joinBasePath(base, '/images/author-photo-all_rights_reserved_aaron_hsieh.webp')} type="image/webp" />
            <img
              src={joinBasePath(base, '/images/author-photo-all_rights_reserved_aaron_hsieh.jpg')}
              alt={i.landing.authorImgAlt}
              width="1000"
              height="600"
              loading="lazy"
              decoding="async"
              class="w-full object-cover object-[70%_center] aspect-[3/4] max-w-xs mx-auto md:max-w-none md:mx-0"
            />
          </picture>
        </div>
      </div>
    </div>
  </section>

  <!-- LIST Principles Exercises -->
  <section aria-label={i.landing.section3AriaLabel} class="py-20 sm:py-28 border-t border-primary/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 items-start">
        <!-- Left: Title + Image + Description + CTA -->
        <div class="flex flex-col md:order-1">
          <h2 class={`${sectionTitle} mb-8`} set:html={i.landing.section3Title}>
          </h2>
          <picture>
            <source srcset={joinBasePath(base, '/images/list-cycle-all_rights_reserved_aaron_hsieh.webp')} type="image/webp" />
            <img
              src={joinBasePath(base, '/images/list-cycle-all_rights_reserved_aaron_hsieh.png')}
              alt={i.landing.listCycleAlt}
              width="1024"
              height="612"
              loading="lazy"
              decoding="async"
              class="w-full mb-10 sm:mb-12 max-w-sm mx-auto md:max-w-none md:mx-0"
            />
          </picture>
          <p class="text-[15px] text-primary/50 leading-relaxed mb-8">
            {i.landing.section3Description}
          </p>
          <div>
            <a href={joinBasePath(base, `/${lang}/resources`)} class="cta-link" data-track="cta_click" data-track-dest="resources">
              {i.landing.section3Cta}
              <svg class="ml-2 w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </a>
          </div>
        </div>
        <!-- Right: Exercise List -->
        <div class="md:order-2 bg-primary/[0.03] border border-primary/10 p-8 sm:p-12">
          <ol class="space-y-5 list-none">
            <li><a href={joinBasePath(base, `/${lang}/exercises/visa-memo`)} class="flex items-center gap-4 hover:bg-primary/5 -mx-3 px-3 py-1 transition-colors" data-track="exercise_start" data-track-exercise="visa-memo">
              <span class="text-2xl font-bold text-primary/20">01</span>
              <span class="text-sm font-medium text-primary/70">{i.landing.exerciseName1}</span>
            </a></li>
            <li><a href={joinBasePath(base, `/${lang}/exercises/star-timeseries`)} class="flex items-center gap-4 hover:bg-primary/5 -mx-3 px-3 py-1 transition-colors" data-track="exercise_start" data-track-exercise="star-timeseries">
              <span class="text-2xl font-bold text-primary/20">02</span>
              <span class="text-sm font-medium text-primary/70">{i.landing.exerciseName2}</span>
            </a></li>
            <li><a href={joinBasePath(base, `/${lang}/exercises/star-questions`)} class="flex items-center gap-4 hover:bg-primary/5 -mx-3 px-3 py-1 transition-colors" data-track="exercise_start" data-track-exercise="star-questions">
              <span class="text-2xl font-bold text-primary/20">03</span>
              <span class="text-sm font-medium text-primary/70">{i.landing.exerciseName3}</span>
            </a></li>
            <li><a href={joinBasePath(base, `/${lang}/exercises/list-dashboard`)} class="flex items-center gap-4 hover:bg-primary/5 -mx-3 px-3 py-1 transition-colors" data-track="exercise_start" data-track-exercise="list-dashboard">
              <span class="text-2xl font-bold text-primary/20">04</span>
              <span class="text-sm font-medium text-primary/70">{i.landing.exerciseName4}</span>
            </a></li>
            <li><a href={joinBasePath(base, `/${lang}/exercises/list-funnel`)} class="flex items-center gap-4 hover:bg-primary/5 -mx-3 px-3 py-1 transition-colors" data-track="exercise_start" data-track-exercise="list-funnel">
              <span class="text-2xl font-bold text-primary/20">05</span>
              <span class="text-sm font-medium text-primary/70">{i.landing.exerciseName5}</span>
            </a></li>
          </ol>
        </div>
      </div>
    </div>
  </section>

  <!-- Coffee Chat -->
  <section aria-label={i.landing.section4AriaLabel} class="pt-16 sm:pt-24 pb-24 sm:pb-36 border-t border-primary/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-x-20 md:gap-y-0 items-start">
        <!-- Left: Title + Quote -->
        <div class="flex flex-col justify-start mb-8 md:mb-0">
          <h2 class={`${sectionTitle} mb-10 md:mb-6`}>
            {i.landing.section4Quote}
          </h2>
        </div>
        <!-- Right: Image -->
        <div class="overflow-hidden md:row-span-2 my-2 md:my-0">
          <picture>
            <source srcset={joinBasePath(base, '/images/aaron-coffee-all_rights_reserved_aaron_hsieh.webp')} type="image/webp" />
            <img
              src={joinBasePath(base, '/images/aaron-coffee-all_rights_reserved_aaron_hsieh.png')}
              alt={i.landing.section4ImgAlt}
              width="1024"
              height="1024"
              loading="lazy"
              decoding="async"
              class="w-full object-contain max-w-xs mx-auto md:max-w-none md:mx-0"
            />
          </picture>
        </div>
        <!-- Left continued: Text + CTA -->
        <div class="flex flex-col justify-start">
          <p class="text-[15px] text-primary/50 leading-relaxed mb-14 font-normal" set:html={i.coffeechat.subtitle}>
          </p>
          <div>
            <a href={joinBasePath(base, `/${lang}/coffee-chat`)} class="cta-link" data-track="cta_click" data-track-dest="coffee-chat">
              {i.landing.section4Cta}
              <svg class="ml-2 w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
  {isRoot && (
    <script is:inline define:vars={{ base }}>
      // Redirect non-English browsers to their locale; English users stay on root
      var lang = navigator.language || (navigator.languages && navigator.languages[0]) || 'en';
      if (lang.startsWith('zh')) {
        window.location.replace((base === '/' ? '' : base) + '/zh-tw/');
      } else if (lang.startsWith('ja')) {
        window.location.replace((base === '/' ? '' : base) + '/ja/');
      } else if (lang.startsWith('ko')) {
        window.location.replace((base === '/' ? '' : base) + '/ko/');
      }
    </script>
  )}
</Layout>
