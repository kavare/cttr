---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';

interface Props {
  title?: string;
  lang?: Lang;
  description?: string;
  ogImage?: string;
}

const { title, lang = 'en', description, ogImage } = Astro.props;
const i = t(lang);
const base = import.meta.env.BASE_URL;
const site = 'https://kavare.github.io';
const pageTitle = title ? `${title} | ${i.site.title}` : i.site.title;
const pageDescription = description || i.site.description;
const canonicalURL = new URL(Astro.url.pathname, site);
const ogImageURL = ogImage ? new URL(ogImage, site).href : `${site}${base}/images/book-cover.png`;

const ogLocaleMap: Record<string, string> = {
  en: 'en_US',
  'zh-tw': 'zh_TW',
  ja: 'ja_JP',
  ko: 'ko_KR',
};
const ogLocale = ogLocaleMap[lang] || 'en_US';

const keywordsMap: Record<string, string> = {
  en: 'Career Coach, Startups, Leadership, International Career, overseas jobs, working abroad, Aaron Hsieh, LIST Principles',
  'zh-tw': '國際職涯, 海外工作, 普通人, 職涯教練, 海外求職, Aaron Hsieh, LIST 原則',
  ja: '海外キャリア, 海外就職, キャリアコーチ, 国際キャリア, 海外転職, Aaron Hsieh, LIST原則',
  ko: '해외 취업, 해외 커리어, 커리어 코치, 국제 커리어, 해외 구직, Aaron Hsieh, LIST 원칙',
};
const keywords = keywordsMap[lang] || keywordsMap.en;

const bookNameMap: Record<string, string> = {
  en: 'A Beginner Guide to Find Your First Overseas Jobs',
  'zh-tw': '普通人的海外求職指南',
  ja: 'はじめての海外キャリアのつくり方',
  ko: '평범한 사람의 해외 취업 가이드',
};

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "name": "Aaron Hsieh",
      "url": `${site}${base}/en/`,
      "jobTitle": "Engineering Manager",
      "worksFor": { "@type": "Organization", "name": "Datadog" },
      "sameAs": [
        "https://www.linkedin.com/in/aarontthsieh/",
        "https://medium.com/dimly-lit"
      ],
      "knowsAbout": ["Career Coaching", "International Career Development", "Software Engineering", "Leadership"]
    },
    {
      "@type": "Book",
      "name": bookNameMap[lang] || bookNameMap.en,
      "author": { "@type": "Person", "name": "Aaron Hsieh" },
      "inLanguage": lang === 'zh-tw' ? 'zh-TW' : lang,
      "description": pageDescription,
      "url": `${site}${base}/${lang}/`
    }
  ]
};
---

<!doctype html>
<html lang={lang === 'zh-tw' ? 'zh-TW' : lang === 'ja' ? 'ja' : lang === 'ko' ? 'ko' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Aaron Hsieh" />
    <meta name="robots" content="index, follow" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Hreflang for international SEO -->
    <link rel="alternate" hreflang="en" href={`${site}${base}/en/`} />
    <link rel="alternate" hreflang="zh-TW" href={`${site}${base}/zh-tw/`} />
    <link rel="alternate" hreflang="ja" href={`${site}${base}/ja/`} />
    <link rel="alternate" hreflang="ko" href={`${site}${base}/ko/`} />
    <link rel="alternate" hreflang="x-default" href={`${site}${base}/en/`} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content={i.site.title} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Source+Serif+4:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Noto+Serif+TC:wght@400;500;600;700&family=Noto+Serif+JP:wght@400;500;600;700&family=Noto+Serif+KR:wght@400;500;600;700&family=Noto+Sans+TC:wght@400;500;600;700;800;900&family=Noto+Sans+JP:wght@400;500;600;700;800;900&family=Noto+Sans+KR:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <title>{pageTitle}</title>
    <!-- PostHog Analytics -->
    <script is:inline>
      !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.async=!0,p.src=s.api_host+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="init capture register register_once register_for_session unregister opt_in_capturing opt_out_capturing has_opted_in_capturing has_opted_out_capturing clear_opt_in_out_capturing debug".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);
      // Replace with your PostHog project API key and host
      // posthog.init('<ph_project_api_key>', {api_host: 'https://app.posthog.com'});
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface text-primary font-sans">
    <Navbar lang={lang} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
