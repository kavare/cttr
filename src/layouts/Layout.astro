---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Analytics from '../components/Analytics.astro';
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';
import { joinBasePath } from '../lib/url';

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  title?: string;
  lang?: Lang;
  description?: string;
  ogImage?: string;
  breadcrumbs?: BreadcrumbItem[];
  pageType?: string;
  canonicalOverride?: string;
}

const { title, lang = 'en', description, ogImage, breadcrumbs, pageType = 'page', canonicalOverride } = Astro.props;
const i = t(lang);
const base = import.meta.env.BASE_URL;
const pageTitle = title ? `${title} | ${i.site.title}` : i.site.title;
const pageDescription = description || i.site.description;
const siteBase = Astro.site ?? Astro.url;
const canonicalURL = canonicalOverride
  ? new URL(joinBasePath(base, canonicalOverride), siteBase)
  : new URL(Astro.url.pathname, siteBase);
const ogImageURL = ogImage
  ? new URL(ogImage, Astro.site ?? Astro.url).href
  : new URL(joinBasePath(base, '/images/book-cover-all_rights_reserved_aaron_hsieh.png'), Astro.site ?? Astro.url).href;

// Derive the page path after the locale prefix for page-specific hreflang
const pathname = Astro.url.pathname;
const basePrefix = base === '/' ? '' : base.replace(/\/$/, '');
const pathAfterBase = basePrefix ? pathname.replace(basePrefix, '') : pathname;
const localePattern = /^\/(en|zh-tw|ja|ko)(\/.*)?$/;
const localeMatch = pathAfterBase.match(localePattern);
const pagePath = localeMatch?.[2] || '/';

const ogLocaleMap: Record<string, string> = {
  en: 'en_US',
  'zh-tw': 'zh_TW',
  ja: 'ja_JP',
  ko: 'ko_KR',
};
const ogLocale = ogLocaleMap[lang] || 'en_US';

const keywordsMap: Record<string, string> = {
  en: 'Career Coach, Startups, Leadership, International Career, overseas jobs, working abroad, Aaron Hsieh, LIST Principles',
  'zh-tw': '國際職涯, 海外工作, 普通人, 職涯教練, 海外求職, Aaron Hsieh, LIST 原則',
  ja: '海外キャリア, 海外就職, キャリアコーチ, 国際キャリア, 海外転職, Aaron Hsieh, LIST原則',
  ko: '해외 취업, 해외 커리어, 커리어 코치, 국제 커리어, 해외 구직, Aaron Hsieh, LIST 원칙',
};
const keywords = keywordsMap[lang] || keywordsMap.en;

const bookNameMap: Record<string, string> = {
  en: 'A Beginner Guide to Find Your First Overseas Jobs',
  'zh-tw': '普通人的海外求職指南',
  ja: 'はじめての海外キャリアのつくり方',
  ko: '평범한 사람의 해외 취업 가이드',
};

const siteOrigin = Astro.site ?? Astro.url;

const jsonLdGraph: Record<string, unknown>[] = [
  {
    "@type": "WebSite",
    "name": i.site.title,
    "url": new URL(joinBasePath(base, `/${lang}/`), siteOrigin).href,
    "inLanguage": lang === 'zh-tw' ? 'zh-TW' : lang,
  },
  {
    "@type": "Person",
    "name": "Aaron Hsieh",
    "url": new URL(joinBasePath(base, '/en/'), siteOrigin).href,
    "jobTitle": "Engineering Manager",
    "worksFor": { "@type": "Organization", "name": "Datadog" },
    "sameAs": [
      "https://www.linkedin.com/in/aarontthsieh/",
      "https://medium.com/dimly-lit"
    ],
    "knowsAbout": ["Career Coaching", "International Career Development", "Software Engineering", "Leadership"]
  },
  {
    "@type": "Book",
    "name": bookNameMap[lang] || bookNameMap.en,
    "author": { "@type": "Person", "name": "Aaron Hsieh" },
    "inLanguage": lang === 'zh-tw' ? 'zh-TW' : lang,
    "description": pageDescription,
    "url": new URL(joinBasePath(base, `/${lang}/`), siteOrigin).href
  },
];

// Add BreadcrumbList if breadcrumbs are provided
if (breadcrumbs && breadcrumbs.length > 0) {
  jsonLdGraph.push({
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbs.map((item, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "name": item.name,
      ...(index < breadcrumbs.length - 1 ? { "item": item.url } : {}),
    })),
  });
}

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": jsonLdGraph,
};
---

<!doctype html>
<html lang={lang === 'zh-tw' ? 'zh-TW' : lang === 'ja' ? 'ja' : lang === 'ko' ? 'ko' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={joinBasePath(base, '/favicon-all_rights_reserved_aaron_hsieh.png')} />
    <link rel="apple-touch-icon" href={joinBasePath(base, '/favicon-all_rights_reserved_aaron_hsieh.png')} />
    <link rel="manifest" href={joinBasePath(base, '/manifest.json')} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f0ede6" />
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Aaron Hsieh" />
    <meta name="robots" content="index, follow" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Hreflang for international SEO (page-specific) -->
    {/* For homepage: EN and x-default point to root / (carries domain authority) */}
    {/* For sub-pages: EN points to /en/{page} as usual */}
    <link rel="alternate" hreflang="en" href={new URL(joinBasePath(base, pagePath === '/' ? '/' : `/en${pagePath}`), siteBase).href} />
    <link rel="alternate" hreflang="zh-TW" href={new URL(joinBasePath(base, `/zh-tw${pagePath}`), siteBase).href} />
    <link rel="alternate" hreflang="ja" href={new URL(joinBasePath(base, `/ja${pagePath}`), siteBase).href} />
    <link rel="alternate" hreflang="ko" href={new URL(joinBasePath(base, `/ko${pagePath}`), siteBase).href} />
    <link rel="alternate" hreflang="x-default" href={new URL(joinBasePath(base, pagePath === '/' ? '/' : `/en${pagePath}`), siteBase).href} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content={i.site.title} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Fonts: base Latin fonts (critical) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&family=Source+Serif+4:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
    {/* Fonts: CJK fonts loaded per locale to reduce payload */}
    {lang === 'zh-tw' && (
      <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;700&family=Noto+Sans+TC:wght@400;700;900&display=swap" rel="stylesheet" />
    )}
    {lang === 'ja' && (
      <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;700&family=Noto+Sans+JP:wght@400;700;900&display=swap" rel="stylesheet" />
    )}
    {lang === 'ko' && (
      <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;700&family=Noto+Sans+KR:wght@400;700;900&display=swap" rel="stylesheet" />
    )}
    <title>{pageTitle}</title>

    <!-- Contentsquare UXA (auto-captures heatmaps, session replay, journeys) -->
    <script is:inline src="https://t.contentsquare.net/uxa/01b80da18a06e.js"></script>

    <!-- PostHog Analytics -->
    <script is:inline>
      !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.crossOrigin="anonymous",p.async=!0,p.src=s.api_host.replace(".i.posthog.com","-assets.i.posthog.com")+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="init capture register register_once register_for_session unregister opt_in_capturing opt_out_capturing has_opted_in_capturing has_opted_out_capturing clear_opt_in_out_capturing debug".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);
      posthog.init('phc_kLpvr2P2pSBzFtAVdBLtCn5Wscp8MzWZLiGqorktLniL', {
        api_host: 'https://us.i.posthog.com',
        capture_pageview: false,
        capture_pageleave: true,
        autocapture: true,
        session_recording: { maskAllInputs: true },
      });
    </script>

    <!-- Mixpanel Analytics -->
    <script is:inline>
      (function(f,b){if(!b.__SV){var e,g,i,h;window.mixpanel=b;b._i=[];b.init=function(e,f,c){function g(a,d){var b=d.split(".");2==b.length&&(a=a[b[0]],d=b[1]);a[d]=function(){a.push([d].concat(Array.prototype.slice.call(arguments,0)))}}var a=b;"undefined"!==typeof c?a=b[c]=[]:c="mixpanel";a.people=a.people||[];a.toString=function(a){var d="mixpanel";"mixpanel"!==c&&(d+="."+c);a||(d+=" (stub)");return d};a.people.toString=function(){return a.toString(1)+".people (stub)"};i="disable time_event track track_pageview track_links track_forms track_with_groups add_group set_group remove_group register register_once alias unregister identify name_tag set_config reset opt_in_tracking opt_out_tracking has_opted_in_tracking has_opted_out_tracking clear_opt_in_out_tracking start_batch_senders people.set people.set_once people.unset people.increment people.append people.union people.track_charge people.clear_charges people.delete_user people.remove".split(" ");for(h=0;h<i.length;h++)g(a,i[h]);var j="set set_once union unset remove delete".split(" ");a.get_group=function(){function b(c){d[c]=function(){call2_args=arguments;call2=[c].concat(Array.prototype.slice.call(call2_args,0));a.push([e,call2])}}for(var d={},e=["get_group"].concat(Array.prototype.slice.call(arguments,0)),c=0;c<j.length;c++)b(j[c]);return d};b._i.push([e,f,c])};b.__SV=1.2;e=f.createElement("script");e.type="text/javascript";e.async=!0;e.src="undefined"!==typeof MIXPANEL_CUSTOM_LIB_URL?MIXPANEL_CUSTOM_LIB_URL:"file:"===f.location.protocol&&"//cdn.mxpnl.com/libs/mixpanel-2-latest.min.js".match(/^\/\//)?"https://cdn.mxpnl.com/libs/mixpanel-2-latest.min.js":"//cdn.mxpnl.com/libs/mixpanel-2-latest.min.js";g=f.getElementsByTagName("script")[0];g.parentNode.insertBefore(e,g)}})(document,window.mixpanel||[]);
      mixpanel.init('cc5828c3ff7426e10e70e1eafc4d6dd5', {
        track_pageview: false,
        persistence: 'localStorage',
      });
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-surface text-primary font-sans">
    <Navbar lang={lang} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
    <Analytics lang={lang} pageType={pageType} />
  </body>
</html>
