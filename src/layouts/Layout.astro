---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n/translations';
import { t } from '../i18n/translations';
import { joinBasePath } from '../lib/url';

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  title?: string;
  lang?: Lang;
  description?: string;
  ogImage?: string;
  breadcrumbs?: BreadcrumbItem[];
}

const { title, lang = 'en', description, ogImage, breadcrumbs } = Astro.props;
const i = t(lang);
const base = import.meta.env.BASE_URL;
const pageTitle = title ? `${title} | ${i.site.title}` : i.site.title;
const pageDescription = description || i.site.description;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
const ogImageURL = ogImage
  ? new URL(ogImage, Astro.site ?? Astro.url).href
  : new URL(joinBasePath(base, '/images/book-cover-all_rights_reserved_aaron_hsieh.png'), Astro.site ?? Astro.url).href;

// Derive the page path after the locale prefix for page-specific hreflang
const pathname = Astro.url.pathname;
const basePrefix = base === '/' ? '' : base.replace(/\/$/, '');
const pathAfterBase = basePrefix ? pathname.replace(basePrefix, '') : pathname;
const localePattern = /^\/(en|zh-tw|ja|ko)(\/.*)?$/;
const localeMatch = pathAfterBase.match(localePattern);
const pagePath = localeMatch?.[2] || '/';

const ogLocaleMap: Record<string, string> = {
  en: 'en_US',
  'zh-tw': 'zh_TW',
  ja: 'ja_JP',
  ko: 'ko_KR',
};
const ogLocale = ogLocaleMap[lang] || 'en_US';

const keywordsMap: Record<string, string> = {
  en: 'Career Coach, Startups, Leadership, International Career, overseas jobs, working abroad, Aaron Hsieh, LIST Principles',
  'zh-tw': '國際職涯, 海外工作, 普通人, 職涯教練, 海外求職, Aaron Hsieh, LIST 原則',
  ja: '海外キャリア, 海外就職, キャリアコーチ, 国際キャリア, 海外転職, Aaron Hsieh, LIST原則',
  ko: '해외 취업, 해외 커리어, 커리어 코치, 국제 커리어, 해외 구직, Aaron Hsieh, LIST 원칙',
};
const keywords = keywordsMap[lang] || keywordsMap.en;

const bookNameMap: Record<string, string> = {
  en: 'A Beginner Guide to Find Your First Overseas Jobs',
  'zh-tw': '普通人的海外求職指南',
  ja: 'はじめての海外キャリアのつくり方',
  ko: '평범한 사람의 해외 취업 가이드',
};

const siteOrigin = Astro.site ?? Astro.url;

const jsonLdGraph: Record<string, unknown>[] = [
  {
    "@type": "WebSite",
    "name": i.site.title,
    "url": new URL(joinBasePath(base, `/${lang}/`), siteOrigin).href,
    "inLanguage": lang === 'zh-tw' ? 'zh-TW' : lang,
  },
  {
    "@type": "Person",
    "name": "Aaron Hsieh",
    "url": new URL(joinBasePath(base, '/en/'), siteOrigin).href,
    "jobTitle": "Engineering Manager",
    "worksFor": { "@type": "Organization", "name": "Datadog" },
    "sameAs": [
      "https://www.linkedin.com/in/aarontthsieh/",
      "https://medium.com/dimly-lit"
    ],
    "knowsAbout": ["Career Coaching", "International Career Development", "Software Engineering", "Leadership"]
  },
  {
    "@type": "Book",
    "name": bookNameMap[lang] || bookNameMap.en,
    "author": { "@type": "Person", "name": "Aaron Hsieh" },
    "inLanguage": lang === 'zh-tw' ? 'zh-TW' : lang,
    "description": pageDescription,
    "url": new URL(joinBasePath(base, `/${lang}/`), siteOrigin).href
  },
];

// Add BreadcrumbList if breadcrumbs are provided
if (breadcrumbs && breadcrumbs.length > 0) {
  jsonLdGraph.push({
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbs.map((item, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "name": item.name,
      ...(index < breadcrumbs.length - 1 ? { "item": item.url } : {}),
    })),
  });
}

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": jsonLdGraph,
};
---

<!doctype html>
<html lang={lang === 'zh-tw' ? 'zh-TW' : lang === 'ja' ? 'ja' : lang === 'ko' ? 'ko' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={joinBasePath(base, '/favicon-all_rights_reserved_aaron_hsieh.png')} />
    <link rel="apple-touch-icon" href={joinBasePath(base, '/favicon-all_rights_reserved_aaron_hsieh.png')} />
    <link rel="manifest" href={joinBasePath(base, '/manifest.json')} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f0ede6" />
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Aaron Hsieh" />
    <meta name="robots" content="index, follow" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Hreflang for international SEO (page-specific) -->
    <link rel="alternate" hreflang="en" href={new URL(joinBasePath(base, `/en${pagePath}`), Astro.site ?? Astro.url).href} />
    <link rel="alternate" hreflang="zh-TW" href={new URL(joinBasePath(base, `/zh-tw${pagePath}`), Astro.site ?? Astro.url).href} />
    <link rel="alternate" hreflang="ja" href={new URL(joinBasePath(base, `/ja${pagePath}`), Astro.site ?? Astro.url).href} />
    <link rel="alternate" hreflang="ko" href={new URL(joinBasePath(base, `/ko${pagePath}`), Astro.site ?? Astro.url).href} />
    <link rel="alternate" hreflang="x-default" href={new URL(joinBasePath(base, `/en${pagePath}`), Astro.site ?? Astro.url).href} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content={i.site.title} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Fonts: base Latin fonts (critical) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&family=Source+Serif+4:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
    {/* Fonts: CJK fonts loaded per locale to reduce payload */}
    {lang === 'zh-tw' && (
      <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;700&family=Noto+Sans+TC:wght@400;700;900&display=swap" rel="stylesheet" />
    )}
    {lang === 'ja' && (
      <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;700&family=Noto+Sans+JP:wght@400;700;900&display=swap" rel="stylesheet" />
    )}
    {lang === 'ko' && (
      <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;700&family=Noto+Sans+KR:wght@400;700;900&display=swap" rel="stylesheet" />
    )}
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-surface text-primary font-sans">
    <Navbar lang={lang} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
